#!/system/bin/sh

PT="/tmp/production_tool"
LOG="/data/local/cubej1_install.log"
BACKUP_ROOT="/data/local/cubej1-backup"
BACKUP_DIR="$BACKUP_ROOT/$(date '+%Y%m%d-%H%M%S')"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG"
}

fail() {
    log "失敗: $*"
    if [ -x /data/local/led_effect.sh ]; then
        /data/local/led_effect.sh blink red 10 >/dev/null 2>&1
    fi
    exit 1
}

run_cmd() {
    log "+ $*"
    "$@" >> "$LOG" 2>&1
    rc=$?
    log "rc=$rc"
    return "$rc"
}

copy_if_exists() {
    src="$1"
    dst="$2"
    if [ -e "$src" ]; then
        run_cmd cp "$src" "$dst" || fail "$src のバックアップに失敗しました"
    else
        log "バックアップ対象なし: $src"
    fi
}

copy_if_exists_unless_ours() {
    src="$1"
    dst="$2"
    marker="$3"
    if [ -e "$src" ]; then
        if grep -q "$marker" "$src" 2>/dev/null; then
            log "本ツール由来のためバックアップしません: $src"
        else
            run_cmd cp "$src" "$dst" || fail "$src のバックアップに失敗しました"
        fi
    else
        log "バックアップ対象なし: $src"
    fi
}

require_file() {
    file="$1"
    if [ ! -f "$file" ]; then
        fail "必要ファイルがありません: $file"
    fi
}

validate_hostname() {
    host="$1"
    case "$host" in
        "")
            return 1
            ;;
        *[!A-Za-z0-9.-]*)
            return 1
            ;;
    esac
    return 0
}

ENABLE_ADB=0
PERSIST_ADB=0
APPLY_WIFI=1
START_BRIDGE=1
DISABLE_CLOUD=1
REPOINT_TLSDATE=1
TLSDATE_HOST="www.google.com"
DISABLE_P2P_AP=1

# 無効化するNextDriveクラウド系サービス(終了済みクラウドへ延々と接続を試み、
# DNSクエリを撒き散らすため)。オフラインのWi-SUN→MQTT電力監視には不要。
CLOUD_SERVICES="sessiond fms fmssecman NDCloudDaemon rds iijschedule transman"

touch "$LOG" 2>/dev/null
log "=== Cube J1 本番導入開始 ==="
log "PT=$PT"

if [ -f "$PT/install_config.sh" ]; then
    # 外部設定を読み込みます。
    # shellcheck disable=SC1090
    . "$PT/install_config.sh"
fi

require_file "$PT/config.json"
require_file "$PT/mqtt_bridge.py"
require_file "$PT/led_effect.sh"
require_file "$PT/mqtt_ha_bridge.rc"
require_file "$PT/wisund_disabled.rc"
require_file "$PT/ndeclite_disabled.rc"
if [ "$DISABLE_P2P_AP" = "1" ]; then
    require_file "$PT/disable_p2p_ap.sh"
    require_file "$PT/disable_p2p_ap.rc"
fi
if [ "$APPLY_WIFI" = "1" ]; then
    require_file "$PT/wpa_supplicant.conf"
fi
if [ "$DISABLE_CLOUD" = "1" ]; then
    for svc in $CLOUD_SERVICES; do
        require_file "$PT/cloud_disabled/$svc.rc"
    done
fi
if [ "$REPOINT_TLSDATE" = "1" ]; then
    require_file "$PT/tlsdated_timesync.rc"
    validate_hostname "$TLSDATE_HOST" || fail "TLSDATE_HOST に使えない文字が含まれています: $TLSDATE_HOST"
fi

run_cmd mkdir -p "$BACKUP_DIR" || fail "バックアップディレクトリを作成できません"
log "バックアップ先: $BACKUP_DIR"
copy_if_exists /system/etc/init/wisund.rc "$BACKUP_DIR/wisund.rc"
copy_if_exists /system/etc/init/ndeclite_agent.rc "$BACKUP_DIR/ndeclite_agent.rc"
copy_if_exists /system/etc/init/mqtt_ha_bridge.rc "$BACKUP_DIR/mqtt_ha_bridge.rc"
copy_if_exists_unless_ours /system/etc/init/disable_p2p_ap.rc "$BACKUP_DIR/disable_p2p_ap.rc" "service disable_p2p_ap"
copy_if_exists /data/misc/wifi/wpa_supplicant.conf "$BACKUP_DIR/wpa_supplicant.conf"
copy_if_exists /data/local/config.json "$BACKUP_DIR/config.json"
copy_if_exists /data/local/mqtt_bridge.py "$BACKUP_DIR/mqtt_bridge.py"
copy_if_exists /data/local/led_effect.sh "$BACKUP_DIR/led_effect.sh"
copy_if_exists_unless_ours /data/local/disable_p2p_ap.sh "$BACKUP_DIR/disable_p2p_ap.sh" "P2P/AP停止処理"
if [ "$DISABLE_CLOUD" = "1" ]; then
    for svc in $CLOUD_SERVICES; do
        copy_if_exists "/system/etc/init/$svc.rc" "$BACKUP_DIR/$svc.rc"
    done
fi
if [ "$REPOINT_TLSDATE" = "1" ]; then
    copy_if_exists /system/etc/init/tlsdated.rc "$BACKUP_DIR/tlsdated.rc"
fi
echo "$BACKUP_DIR" > "$BACKUP_ROOT/latest"
echo "installed_at=$(date '+%Y-%m-%d %H:%M:%S')" > "$BACKUP_DIR/install_manifest.txt"

run_cmd cp "$PT/led_effect.sh" /data/local/led_effect.sh || fail "led_effect.sh の配置に失敗しました"
run_cmd chmod 755 /data/local/led_effect.sh || fail "led_effect.sh の権限設定に失敗しました"

# ADB TCPはinstall_config.shの値どおりに必ず状態を揃えます。
# 過去の導入で永続化された設定が残っていても、ここで上書き・解除されます。
if [ "$ENABLE_ADB" = "1" ]; then
    log "ADB TCPを有効化します"
    run_cmd setprop service.adb.tcp.port 5555 || fail "ADB TCPの有効化に失敗しました"
    if [ "$PERSIST_ADB" = "1" ]; then
        log "PERSIST_ADB=1 のため、ADB TCP設定を永続化します"
        run_cmd setprop persist.adb.tcp.port 5555 || fail "ADB TCP永続設定に失敗しました"
        run_cmd setprop persist.sys.usb.config mtp,adb || fail "USB設定の永続化に失敗しました"
    else
        log "PERSIST_ADB=0 のため、永続設定を解除します(今回の起動中のみ有効)"
        run_cmd setprop persist.adb.tcp.port -1
    fi
else
    log "ENABLE_ADB=0 のため、ADB TCPを無効化します(永続設定も解除)"
    run_cmd setprop service.adb.tcp.port -1
    run_cmd setprop persist.adb.tcp.port -1
fi
run_cmd stop adbd
sleep 1
run_cmd start adbd || fail "adbd の起動に失敗しました"

if [ "$APPLY_WIFI" = "1" ]; then
    log "Wi-Fi設定を適用します"
    run_cmd cp "$PT/wpa_supplicant.conf" /data/misc/wifi/wpa_supplicant.conf || fail "Wi-Fi設定のコピーに失敗しました"
    if [ "$DISABLE_P2P_AP" = "1" ] && ! grep -q '^p2p_disabled=1' /data/misc/wifi/wpa_supplicant.conf; then
        log "Wi-Fi Direct/P2Pを無効化する設定を追加します"
        echo "p2p_disabled=1" >> /data/misc/wifi/wpa_supplicant.conf
    fi
    run_cmd chmod 660 /data/misc/wifi/wpa_supplicant.conf || fail "Wi-Fi設定の権限設定に失敗しました"
    run_cmd chown system:wifi /data/misc/wifi/wpa_supplicant.conf || fail "Wi-Fi設定の所有者変更に失敗しました"
    run_cmd wpa_cli -p /data/misc/wifi/sockets -i wlan0 reconfigure
    sleep 8
fi

log "ブリッジ本体を配置します"
run_cmd cp "$PT/config.json" /data/local/config.json || fail "config.json の配置に失敗しました"
run_cmd cp "$PT/mqtt_bridge.py" /data/local/mqtt_bridge.py || fail "mqtt_bridge.py の配置に失敗しました"
run_cmd chmod 600 /data/local/config.json || fail "config.json の権限設定に失敗しました"
run_cmd chmod 755 /data/local/mqtt_bridge.py || fail "mqtt_bridge.py の権限設定に失敗しました"
if [ "$DISABLE_P2P_AP" = "1" ]; then
    run_cmd cp "$PT/disable_p2p_ap.sh" /data/local/disable_p2p_ap.sh || fail "disable_p2p_ap.sh の配置に失敗しました"
    run_cmd chmod 755 /data/local/disable_p2p_ap.sh || fail "disable_p2p_ap.sh の権限設定に失敗しました"
fi

log "rootファイルシステムを書き込み可能にします"
run_cmd mount -o rw,remount / || fail "rootファイルシステムの再マウントに失敗しました"

log "標準Wi-SUN関連サービスを無効化し、MQTTブリッジをinitへ登録します"
run_cmd cp "$PT/wisund_disabled.rc" /system/etc/init/wisund.rc || fail "wisund.rc の配置に失敗しました"
run_cmd cp "$PT/ndeclite_disabled.rc" /system/etc/init/ndeclite_agent.rc || fail "ndeclite_agent.rc の配置に失敗しました"
run_cmd cp "$PT/mqtt_ha_bridge.rc" /system/etc/init/mqtt_ha_bridge.rc || fail "mqtt_ha_bridge.rc の配置に失敗しました"
if [ "$DISABLE_P2P_AP" = "1" ]; then
    run_cmd cp "$PT/disable_p2p_ap.rc" /system/etc/init/disable_p2p_ap.rc || fail "disable_p2p_ap.rc の配置に失敗しました"
    run_cmd chmod 644 /system/etc/init/disable_p2p_ap.rc
fi

run_cmd stop wisund
run_cmd stop NDEcLiteAgent
sleep 2

if [ "$DISABLE_P2P_AP" = "1" ]; then
    log "Wi-Fi Direct/P2P APを停止します"
    run_cmd /system/bin/sh /data/local/disable_p2p_ap.sh
    run_cmd stop disable_p2p_ap
    run_cmd start disable_p2p_ap
fi

if [ "$DISABLE_CLOUD" = "1" ]; then
    log "NextDriveクラウド系サービスを無効化します(DNSクエリ抑止)"
    for svc in $CLOUD_SERVICES; do
        run_cmd cp "$PT/cloud_disabled/$svc.rc" "/system/etc/init/$svc.rc" || fail "$svc.rc の配置に失敗しました"
        run_cmd chmod 644 "/system/etc/init/$svc.rc"
        run_cmd stop "$svc"
    done
fi

if [ "$REPOINT_TLSDATE" = "1" ]; then
    # tlsdatedの時刻ソースは既定でnewsignaling.nextdrive.io(終了済み)に
    # ハードコードされ同期不能。生きた公開TLSホストへ向け直し、時刻同期を
    # 復活させると同時にnextdriveへのDNSクエリをなくす。
    log "tlsdateの時刻同期先を $TLSDATE_HOST へ向け直します"
    run_cmd cp "$PT/tlsdated_timesync.rc" /system/etc/init/tlsdated.rc || fail "tlsdated.rc の配置に失敗しました"
    if [ "$TLSDATE_HOST" != "www.google.com" ]; then
        run_cmd sed -i "s/www\\.google\\.com/$TLSDATE_HOST/g" /system/etc/init/tlsdated.rc
    fi
    run_cmd chmod 644 /system/etc/init/tlsdated.rc
    # 旧設定(newsignaling向け)のtlsdatedを止める。新rcは再起動後に有効化される。
    run_cmd stop tlsdated
    # 今すぐ一度だけ同期して時計を合わせておく。
    run_cmd /usr/sbin/tlsdate -C /etc/ssl/certs -l -v -H "$TLSDATE_HOST" -p 443
fi

if [ "$START_BRIDGE" = "1" ]; then
    log "MQTTブリッジを起動します"
    run_cmd stop mqtt_ha_bridge
    sleep 1
    run_cmd start mqtt_ha_bridge || fail "MQTTブリッジの起動に失敗しました"
fi

log "=== Cube J1 本番導入完了 ==="
/data/local/led_effect.sh blink white 10 >/dev/null 2>&1
